# Auth
JWT_SECRET=your-strong-random-secret-here   # Required — generate with: openssl rand -hex 32

# Active provider: claude | openai | gemini
AI_PROVIDER=claude

# API Keys
AI_CLAUDE_API_KEY=your_anthropic_key
AI_OPENAI_API_KEY=your_openai_key
AI_GEMINI_API_KEY=your_gemini_key
GROQ_API_KEY=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         # Free at console.groq.com — enables Groq as primary provider

# OpenRouter (optional — enables last-resort fallback chain)
AI_OPENROUTER_API_KEY=your_openrouter_key

# Models (optional — defaults shown)
AI_CLAUDE_MODEL=claude-sonnet-4-0
AI_OPENAI_MODEL=gpt-4o
AI_GEMINI_MODEL=gemini-1.5-flash
