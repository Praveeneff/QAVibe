generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(tester)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tokenUsed    Int       @default(0)
  tokenResetAt DateTime?

  ownedProjects      Project[]        @relation("ProjectOwner")
  projectMemberships ProjectMember[]
  assignedTestCases  TestCase[]       @relation("TestCaseAssignee")
  assignedTestRuns   TestRun[]        @relation("TestRunAssignee")
  tokenLimits        UserTokenLimit[]
  aiLogs             AiGenerationLog[]
}

model TestCase {
  id             String       @id @default(uuid())
  tcId           String       @unique @default("")
  title          String
  description    String?
  steps          String?
  expectedResult String?
  preconditions  String?
  tags           String?
  automationId   String?
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  category       String       @default("functional")
  executionType  String       @default("manual")
  priority       String       @default("P2")
  severity       String       @default("medium")
  suiteId        String?
  createdBy      String?
  projectId      String?
  assignedTo     String?
  suite          TestSuite?   @relation(fields: [suiteId], references: [id])
  results        TestResult[]
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee       User?        @relation("TestCaseAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
}

model TestSuite {
  id          String      @id @default(uuid())
  name        String
  description String?
  depth       Int         @default(0) // 0=Suite, 1=Sub-suite, 2=Group
  parentId    String?
  projectId   String?
  parent      TestSuite?  @relation("SuiteTree", fields: [parentId], references: [id])
  children    TestSuite[] @relation("SuiteTree")
  createdAt   DateTime    @default(now())
  createdBy   String?
  testCases   TestCase[]
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model TestRun {
  id           String       @id @default(cuid())
  name         String
  status       String       @default("pending")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  environment  String       @default("staging")
  browser      String?
  buildVersion String?
  device       String?
  createdBy    String?
  sourceRunId  String?
  projectId    String?
  assignedTo   String?
  results      TestResult[]
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee     User?        @relation("TestRunAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
}

model TestResult {
  id            String   @id @default(cuid())
  testCaseId    String
  testRunId     String
  status        String   @default("pending")
  notes         String?
  screenshotUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  testCase      TestCase @relation(fields: [testCaseId], references: [id])
  testRun       TestRun  @relation(fields: [testRunId], references: [id])
}

model TestCaseHistory {
  id         String   @id @default(cuid())
  testCaseId String
  snapshot   String
  changedBy  String?
  changeType String
  changedAt  DateTime @default(now())
  version    Int
}

model AiGenerationLog {
  id           String   @id @default(cuid())
  provider     String
  promptTokens Int?
  latencyMs    Int
  caseCount    Int
  fallbackFrom String?
  createdAt    DateTime @default(now())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum Role {
  admin
  tester
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User             @relation("ProjectOwner", fields: [createdBy], references: [id])
  members     ProjectMember[]
  testCases   TestCase[]
  testSuites  TestSuite[]
  testRuns    TestRun[]
  tokenLimits UserTokenLimit[]
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

enum ProjectRole {
  OWNER
  MEMBER
}

model UserTokenLimit {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  limitTokens Int      @default(50000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}
