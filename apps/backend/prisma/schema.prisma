generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(tester)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TestCase {
  id             String       @id @default(uuid())
  tcId           String       @unique @default("")
  title          String
  description    String?
  steps          String?
  expectedResult String?
  preconditions  String?
  tags           String?
  automationId   String?
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  category       String       @default("functional")
  executionType  String       @default("manual")
  priority       String       @default("P2")
  severity       String       @default("medium")
  suiteId        String?
  createdBy      String?
  suite          TestSuite?   @relation(fields: [suiteId], references: [id])
  results        TestResult[]
}

model TestSuite {
  id          String      @id @default(uuid())
  name        String
  description String?
  depth       Int         @default(0) // 0=Suite, 1=Sub-suite, 2=Group
  parentId    String?
  parent      TestSuite?  @relation("SuiteTree", fields: [parentId], references: [id])
  children    TestSuite[] @relation("SuiteTree")
  createdAt   DateTime    @default(now())
  createdBy   String?
  testCases   TestCase[]
}

model TestRun {
  id           String       @id @default(cuid())
  name         String
  status       String       @default("pending")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  environment  String       @default("staging")
  browser      String?
  buildVersion String?
  device       String?
  createdBy    String?
  sourceRunId  String?
  results      TestResult[]
}

model TestResult {
  id            String   @id @default(cuid())
  testCaseId    String
  testRunId     String
  status        String   @default("pending")
  notes         String?
  screenshotUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  testCase      TestCase @relation(fields: [testCaseId], references: [id])
  testRun       TestRun  @relation(fields: [testRunId], references: [id])
}

model TestCaseHistory {
  id         String   @id @default(cuid())
  testCaseId String
  snapshot   String
  changedBy  String?
  changeType String
  changedAt  DateTime @default(now())
  version    Int
}

model AiGenerationLog {
  id           String   @id @default(cuid())
  provider     String
  promptTokens Int?
  latencyMs    Int
  caseCount    Int
  fallbackFrom String?
  createdAt    DateTime @default(now())
}

enum Role {
  admin
  tester
}
